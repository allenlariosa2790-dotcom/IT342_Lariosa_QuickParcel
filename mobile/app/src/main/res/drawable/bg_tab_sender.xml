<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_selected="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/quickparcel_blue" />
            <corners android:radius="8dp" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/quickparcel_gray_light" />
            <corners android:radius="8dp" />
            <stroke android:width="1dp" android:color="@color/quickparcel_gray" />
        </shape>
    </item>
</selector>