<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_stats_card"
    android:padding="12dp"
    android:layout_marginBottom="8dp">

    <!-- Tracking Number and Earnings Row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/tvTrackingNumber"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="QP-2301"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="#111827"/>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="end">

            <TextView
                android:id="@+id/tvEarnings"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="$12"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#2563EB"/>

            <TextView
                android:id="@+id/tvDistance"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="2.3 km"
                android:textSize="12sp"
                android:textColor="#6B7280"/>

        </LinearLayout>

    </LinearLayout>

    <!-- Pickup Location -->
    <TextView
        android:id="@+id/tvPickup"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="From: Downtown Mall"
        android:textSize="13sp"
        android:textColor="#6B7280"
        android:layout_marginTop="10dp"/>

    <!-- Dropoff Location -->
    <TextView
        android:id="@+id/tvDropoff"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="To: Oak Street 123"
        android:textSize="13sp"
        android:textColor="#6B7280"
        android:layout_marginTop="2dp"/>

    <!-- Accept Button -->
    <Button
        android:id="@+id/btnAccept"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:layout_marginTop="12dp"
        android:text="Accept"
        android:textSize="14sp"
        android:textColor="#FFFFFF"
        android:textAllCaps="false"
        android:textStyle="bold"
        android:backgroundTint="#2563EB"
        android:stateListAnimator="@null"/>

</LinearLayout>