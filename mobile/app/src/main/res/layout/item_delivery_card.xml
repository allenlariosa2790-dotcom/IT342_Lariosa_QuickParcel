<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    app:cardCornerRadius="8dp"
    app:cardElevation="1dp"
    android:clickable="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tv_tracking_number"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="QP-123456"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/quickparcel_blue" />

            <TextView
                android:id="@+id/tv_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PENDING"
                android:textSize="10sp"
                android:paddingHorizontal="8dp"
                android:paddingVertical="4dp"
                android:background="@drawable/bg_status_pending"
                android:textColor="@color/white" />
        </LinearLayout>

        <TextView
            android:id="@+id/tv_pickup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Pickup: "
            android:textSize="12sp"
            android:textColor="@color/quickparcel_gray"
            android:layout_marginTop="8dp"
            android:maxLines="1"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/tv_dropoff"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Dropoff: "
            android:textSize="12sp"
            android:textColor="@color/quickparcel_gray"
            android:maxLines="1"
            android:ellipsize="end" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tv_cost"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="₱0.00"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/quickparcel_blue" />

            <TextView
                android:id="@+id/tv_date"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="10sp"
                android:textColor="@color/quickparcel_gray" />
        </LinearLayout>

        <!-- Status Update Buttons Container (Only visible for Riders) -->
        <LinearLayout
            android:id="@+id/status_buttons_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="12dp"
            android:visibility="gone">

            <Button
                android:id="@+id/btn_picked_up"
                android:layout_width="0dp"
                android:layout_height="32dp"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                android:text="📦 Picked Up"
                android:textSize="10sp"
                style="@style/Widget.MaterialComponents.Button"
                android:backgroundTint="@color/quickparcel_yellow" />

            <Button
                android:id="@+id/btn_in_transit"
                android:layout_width="0dp"
                android:layout_height="32dp"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="4dp"
                android:text="🚚 In Transit"
                android:textSize="10sp"
                style="@style/Widget.MaterialComponents.Button"
                android:backgroundTint="@color/quickparcel_blue" />

            <Button
                android:id="@+id/btn_delivered"
                android:layout_width="0dp"
                android:layout_height="32dp"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:text="✅ Delivered"
                android:textSize="10sp"
                style="@style/Widget.MaterialComponents.Button"
                android:backgroundTint="@color/quickparcel_green" />
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>