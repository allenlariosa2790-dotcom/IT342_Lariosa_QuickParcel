<?xml version="1.0" encoding="utf-8"?>
<androidx.swiperefreshlayout.widget.SwipeRefreshLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/swipe_refresh"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/quickparcel_gray_light">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Welcome Banner -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp"
                    android:background="@color/quickparcel_blue">

                    <TextView
                        android:id="@+id/tv_welcome"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Welcome back, Rider!"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="@color/white" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Ready to earn today?"
                        android:textSize="14sp"
                        android:textColor="@color/white"
                        android:alpha="0.8"
                        android:layout_marginTop="4dp" />

                    <TextView
                        android:id="@+id/tv_today_earnings"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="₱0"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:textColor="@color/white"
                        android:layout_marginTop="12dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Stats Cards -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    app:cardCornerRadius="8dp"
                    app:cardElevation="2dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="12dp">
                        <TextView
                            android:id="@+id/tv_completed_count"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textSize="24sp"
                            android:textStyle="bold"
                            android:textColor="@color/quickparcel_blue" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Deliveries"
                            android:textSize="12sp"
                            android:textColor="@color/quickparcel_gray" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="4dp"
                    android:layout_marginEnd="4dp"
                    app:cardCornerRadius="8dp"
                    app:cardElevation="2dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="12dp">
                        <TextView
                            android:id="@+id/tv_week_earnings"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="₱0"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:textColor="@color/quickparcel_green" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="This Week"
                            android:textSize="12sp"
                            android:textColor="@color/quickparcel_gray" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    app:cardCornerRadius="8dp"
                    app:cardElevation="2dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="12dp">
                        <TextView
                            android:id="@+id/tv_total_earnings"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="₱0"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:textColor="@color/quickparcel_blue" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Total"
                            android:textSize="12sp"
                            android:textColor="@color/quickparcel_gray" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <!-- Active Delivery Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Active Delivery"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_active_delivery"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/tv_active_tracking"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="QP-000000"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="@color/quickparcel_blue" />

                    <TextView
                        android:id="@+id/tv_active_status"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ACCEPTED"
                        android:textSize="11sp"
                        android:paddingHorizontal="8dp"
                        android:paddingVertical="2dp"
                        android:layout_marginTop="4dp"
                        android:background="@drawable/bg_status_accepted"
                        android:textColor="@color/white" />

                    <TextView
                        android:id="@+id/tv_active_pickup"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Pickup: Address"
                        android:textSize="12sp"
                        android:textColor="@color/quickparcel_gray"
                        android:layout_marginTop="8dp"
                        android:maxLines="1"
                        android:ellipsize="end" />

                    <TextView
                        android:id="@+id/tv_active_dropoff"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Dropoff: Address"
                        android:textSize="12sp"
                        android:textColor="@color/quickparcel_gray"
                        android:maxLines="1"
                        android:ellipsize="end" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="12dp"
                        android:gravity="center_vertical">

                        <TextView
                            android:id="@+id/tv_active_earning"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="₱0"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="@color/quickparcel_blue" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_view_tracking"
                            android:layout_width="wrap_content"
                            android:layout_height="32dp"
                            android:text="Track"
                            android:textSize="12sp"
                            app:cornerRadius="6dp"
                            android:backgroundTint="@color/quickparcel_blue" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- No Active Delivery -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_no_active"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                android:visibility="visible">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="24dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🚗"
                        android:textSize="40sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="No active delivery"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_marginTop="8dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Browse available deliveries"
                        android:textSize="12sp"
                        android:textColor="@color/quickparcel_gray" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_browse_deliveries"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:text="Browse Deliveries"
                        android:layout_marginTop="12dp"
                        app:cornerRadius="8dp"
                        android:backgroundTint="@color/quickparcel_blue" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Active Deliveries List Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Your Active Deliveries"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/btn_view_all_active"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="View All →"
                    android:textSize="12sp"
                    android:textColor="@color/quickparcel_blue"
                    android:clickable="true" />
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_active_deliveries"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false" />

            <TextView
                android:id="@+id/tv_active_empty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="No active deliveries"
                android:gravity="center"
                android:padding="24dp"
                android:textSize="13sp"
                android:textColor="@color/quickparcel_gray"
                android:visibility="gone" />

            <!-- Quick Actions -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Quick Actions"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_available_deliveries"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:text="Available"
                    android:textSize="12sp"
                    app:cornerRadius="8dp"
                    android:backgroundTint="@color/quickparcel_blue" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_earnings"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:text="Earnings"
                    android:textSize="12sp"
                    app:cornerRadius="8dp"
                    android:backgroundTint="@color/quickparcel_gray" />
            </LinearLayout>

            <!-- Recent Deliveries -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Recent Deliveries"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_recent_deliveries"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false" />

            <!-- Loading Progress -->
            <ProgressBar
                android:id="@+id/progress_bar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="24dp"
                android:visibility="gone" />

        </LinearLayout>
    </ScrollView>
</androidx.swiperefreshlayout.widget.SwipeRefreshLayout>