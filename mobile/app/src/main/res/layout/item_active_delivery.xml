<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_stats_card"
    android:padding="12dp"
    android:layout_marginBottom="8dp">

    <!-- Tracking Number and Status Row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/tvTrackingNumber"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="QP-2301"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#333"/>

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="In Transit"
            android:textSize="11sp"
            android:paddingHorizontal="8dp"
            android:paddingVertical="4dp"
            android:background="@drawable/bg_status_pending"
            android:textColor="#FFFFFF"/>

    </LinearLayout>

    <!-- Pickup Location -->
    <TextView
        android:id="@+id/tvPickup"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="From: Downtown Mall"
        android:textSize="12sp"
        android:textColor="#666"
        android:layout_marginTop="8dp"/>

    <!-- Dropoff Location -->
    <TextView
        android:id="@+id/tvDropoff"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="To: Oak Street 123"
        android:textSize="12sp"
        android:textColor="#666"/>

    <!-- Rider and ETA Row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="8dp"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/tvRider"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Rider: Michael J."
            android:textSize="11sp"
            android:textColor="#2563EB"/>

        <TextView
            android:id="@+id/tvEta"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ETA: 15 min"
            android:textSize="11sp"
            android:textColor="#10B981"/>

    </LinearLayout>

    <!-- Track Button -->
    <Button
        android:id="@+id/btnTrack"
        android:layout_width="match_parent"
        android:layout_height="36dp"
        android:layout_marginTop="8dp"
        android:text="Track Delivery"
        android:textSize="12sp"
        android:textColor="#FFFFFF"
        android:textAllCaps="false"
        android:backgroundTint="#2563EB"/>

</LinearLayout>