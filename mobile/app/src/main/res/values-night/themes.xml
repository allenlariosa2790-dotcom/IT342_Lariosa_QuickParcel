<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.QuickParcel" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="android:statusBarColor">@color/quickparcel_blue</item>
        <item name="android:windowBackground">@color/quickparcel_gray_light</item>
        <item name="colorPrimary">@color/quickparcel_blue</item>
        <item name="colorPrimaryDark">@color/quickparcel_blue_dark</item>
        <item name="colorAccent">@color/quickparcel_blue</item>
        <item name="materialCardViewStyle">@style/Widget.MaterialComponents.CardView</item>
    </style>

    <!-- Style for circular profile image -->
    <style name="CircleImageView">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>
</resources>